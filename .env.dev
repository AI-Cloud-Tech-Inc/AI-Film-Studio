# API Keys - Get free tiers from these providers
OPENAI_API_KEY=
STABILITY_API_KEY=
REPLICATE_API_KEY=
HUGGINGFACE_TOKEN=

# Database - SQLite for local development
DATABASE_URL=sqlite:///./aifilm.db

# Redis - Optional for development
REDIS_URL=redis://localhost:6379/0

# Storage - Local filesystem
STORAGE_TYPE=local
STORAGE_PATH=./storage

# AI Model Configuration
MODEL_CACHE_DIR=./ai-models/cache
USE_GPU=false  # Set to true if you have CUDA GPU
GPU_DEVICE=0
MAX_VIDEO_DURATION=60
MAX_RESOLUTION=1920x1080

# Application Settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Security - Change these in production
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET=dev-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# Queue Configuration - Use Redis if available, otherwise in-memory
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=./logs/app.log

# Video Processing
FFMPEG_PATH=ffmpeg  # Assumes ffmpeg is in PATH
TEMP_DIR=./storage/temp
MAX_UPLOAD_SIZE=500000000  # 500MB
