# ============================================================================
# AI FILM STUDIO - ENTERPRISE ENVIRONMENT CONFIGURATION
# ============================================================================
# Environment: Production | Staging | Development
# Version: 1.0.0
# Last Updated: 2026-02-01
# ============================================================================

# ============================================================================
# DEPLOYMENT ENVIRONMENT
# ============================================================================
NODE_ENV=production
APP_ENV=production  # production | staging | development
DEPLOYMENT_REGION=us-east-1
AVAILABILITY_ZONE=us-east-1a,us-east-1b,us-east-1c
CLUSTER_NAME=aifilm-production
SERVICE_NAME=ai-film-studio
VERSION=1.0.0

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=AI-Film-Studio
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4
APP_THREADS_PER_WORKER=2
APP_MAX_REQUESTS=1000
APP_MAX_REQUESTS_JITTER=50
APP_TIMEOUT=300
APP_KEEPALIVE=65
APP_GRACEFUL_TIMEOUT=30

# URLs
FRONTEND_URL=https://studio.ai-film.com
BACKEND_URL=https://api.ai-film.com
API_GATEWAY_URL=https://gateway.ai-film.com
CDN_URL=https://cdn.ai-film.com
WEBSOCKET_URL=wss://ws.ai-film.com

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================

# Secrets Management (Use AWS Secrets Manager, Azure Key Vault, or HashiCorp Vault)
SECRETS_PROVIDER=aws-secrets-manager  # aws-secrets-manager | azure-keyvault | hashicorp-vault
SECRETS_REGION=us-east-1
SECRETS_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:aifilm-prod

# Encryption
SECRET_KEY=${AWS_SECRET:aifilm/production/secret-key}
ENCRYPTION_KEY=${AWS_SECRET:aifilm/production/encryption-key}
FIELD_ENCRYPTION_KEY=${AWS_SECRET:aifilm/production/field-encryption-key}

# JWT Authentication
JWT_SECRET=${AWS_SECRET:aifilm/production/jwt-secret}
JWT_ALGORITHM=RS256  # Use asymmetric encryption in production
JWT_PUBLIC_KEY_PATH=/etc/ssl/certs/jwt-public.pem
JWT_PRIVATE_KEY_PATH=/etc/ssl/private/jwt-private.pem
JWT_ACCESS_TOKEN_EXPIRE=900  # 15 minutes
JWT_REFRESH_TOKEN_EXPIRE=604800  # 7 days
JWT_ISSUER=ai-film-studio
JWT_AUDIENCE=api.ai-film.com

# OAuth2 / SAML (Enterprise SSO)
OAUTH2_ENABLED=true
OAUTH2_PROVIDER=okta  # okta | auth0 | azure-ad | google
OAUTH2_CLIENT_ID=${AWS_SECRET:aifilm/production/oauth-client-id}
OAUTH2_CLIENT_SECRET=${AWS_SECRET:aifilm/production/oauth-client-secret}
OAUTH2_REDIRECT_URI=https://studio.ai-film.com/auth/callback
OAUTH2_SCOPE=openid profile email
SAML_ENABLED=true
SAML_ENTITY_ID=https://api.ai-film.com/saml/metadata
SAML_SSO_URL=https://sso.enterprise.com/saml
SAML_X509_CERT_PATH=/etc/ssl/certs/saml.crt

# API Keys (Stored in Secrets Manager)
OPENAI_API_KEY=${AWS_SECRET:aifilm/production/openai-key}
STABILITY_API_KEY=${AWS_SECRET:aifilm/production/stability-key}
REPLICATE_API_KEY=${AWS_SECRET:aifilm/production/replicate-key}
HUGGINGFACE_TOKEN=${AWS_SECRET:aifilm/production/huggingface-token}
ANTHROPIC_API_KEY=${AWS_SECRET:aifilm/production/anthropic-key}
GOOGLE_AI_API_KEY=${AWS_SECRET:aifilm/production/google-ai-key}

# CORS & Security Headers
CORS_ORIGINS=https://studio.ai-film.com,https://admin.ai-film.com
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400
ALLOWED_HOSTS=api.ai-film.com,gateway.ai-film.com
CSRF_PROTECTION=true
CSRF_COOKIE_SECURE=true
CSRF_COOKIE_HTTPONLY=true
CSRF_COOKIE_SAMESITE=strict

# Security Headers
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff
X_XSS_PROTECTION=1; mode=block
REFERRER_POLICY=strict-origin-when-cross-origin

# ============================================================================
# DATABASE - PRIMARY (PostgreSQL with High Availability)
# ============================================================================
DATABASE_TYPE=postgresql
DATABASE_HOST=aifilm-prod-cluster.cluster-abc123.us-east-1.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_NAME=aifilm_production
DATABASE_USER=${AWS_SECRET:aifilm/production/db-user}
DATABASE_PASSWORD=${AWS_SECRET:aifilm/production/db-password}
DATABASE_SSL_MODE=require
DATABASE_SSL_CERT=/etc/ssl/certs/rds-ca-bundle.pem

# Connection Pool
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=false

# Read Replicas (for read-heavy operations)
DATABASE_READ_REPLICA_1=aifilm-prod-reader-1.abc123.us-east-1.rds.amazonaws.com
DATABASE_READ_REPLICA_2=aifilm-prod-reader-2.abc123.us-east-1.rds.amazonaws.com
DATABASE_READ_REPLICA_ENABLED=true

# Database URL (Combined)
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?sslmode=${DATABASE_SSL_MODE}

# Backup & Recovery
DATABASE_BACKUP_ENABLED=true
DATABASE_BACKUP_RETENTION_DAYS=30
DATABASE_POINT_IN_TIME_RECOVERY=true

# ============================================================================
# CACHE & SESSION STORE (Redis Cluster)
# ============================================================================
REDIS_CLUSTER_ENABLED=true
REDIS_CLUSTER_NODES=aifilm-redis-001.abc123.0001.use1.cache.amazonaws.com:6379,aifilm-redis-002.abc123.0001.use1.cache.amazonaws.com:6379,aifilm-redis-003.abc123.0001.use1.cache.amazonaws.com:6379
REDIS_PASSWORD=${AWS_SECRET:aifilm/production/redis-password}
REDIS_SSL=true
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL=30

# Redis URLs
REDIS_URL=rediss://:${REDIS_PASSWORD}@aifilm-redis-001.abc123.0001.use1.cache.amazonaws.com:6379/0
REDIS_CACHE_URL=rediss://:${REDIS_PASSWORD}@aifilm-redis-001.abc123.0001.use1.cache.amazonaws.com:6379/1
REDIS_SESSION_URL=rediss://:${REDIS_PASSWORD}@aifilm-redis-001.abc123.0001.use1.cache.amazonaws.com:6379/2

# ============================================================================
# CLOUD STORAGE (Multi-Region with Replication)
# ============================================================================
STORAGE_TYPE=s3  # s3 | azure | gcp | hybrid
STORAGE_PROVIDER=aws

# AWS S3 Primary
AWS_ACCESS_KEY_ID=${AWS_SECRET:aifilm/production/aws-access-key}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET:aifilm/production/aws-secret-key}
AWS_REGION=us-east-1
AWS_S3_BUCKET_VIDEOS=aifilm-prod-videos-use1
AWS_S3_BUCKET_UPLOADS=aifilm-prod-uploads-use1
AWS_S3_BUCKET_OUTPUTS=aifilm-prod-outputs-use1
AWS_S3_BUCKET_MODELS=aifilm-prod-models-use1
AWS_S3_BUCKET_BACKUPS=aifilm-prod-backups-use1
AWS_S3_ENCRYPTION=AES256
AWS_S3_VERSIONING=true
AWS_S3_LIFECYCLE_ENABLED=true
AWS_S3_TRANSFER_ACCELERATION=true

# Multi-Region Replication
AWS_S3_REPLICATION_ENABLED=true
AWS_S3_REPLICA_REGION=eu-west-1
AWS_S3_REPLICA_BUCKET=aifilm-prod-videos-euw1

# CloudFront CDN
CDN_ENABLED=true
CDN_DISTRIBUTION_ID=E1ABCDEFGHIJK
CDN_DOMAIN=cdn.ai-film.com
CDN_INVALIDATION_PATHS=/videos/*,/images/*

# Azure Blob Storage (Multi-cloud backup)
AZURE_STORAGE_ACCOUNT=${AWS_SECRET:aifilm/production/azure-storage-account}
AZURE_STORAGE_KEY=${AWS_SECRET:aifilm/production/azure-storage-key}
AZURE_STORAGE_CONTAINER=aifilm-backup

# Google Cloud Storage (Multi-cloud backup)
GCP_PROJECT_ID=aifilm-production
GCP_BUCKET_NAME=aifilm-prod-backup
GCP_CREDENTIALS_PATH=/etc/gcp/service-account.json

# ============================================================================
# MESSAGE QUEUE & EVENT STREAMING
# ============================================================================

# Celery (Background Tasks)
CELERY_BROKER_URL=sqs://  # Use SQS for scalability
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@aifilm-redis-001.abc123.0001.use1.cache.amazonaws.com:6379/3
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# AWS SQS
AWS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/aifilm-prod-tasks
AWS_SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/123456789012/aifilm-prod-dlq

# Apache Kafka (Event Streaming)
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=kafka-1.aifilm.internal:9092,kafka-2.aifilm.internal:9092,kafka-3.aifilm.internal:9092
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512
KAFKA_SASL_USERNAME=${AWS_SECRET:aifilm/production/kafka-username}
KAFKA_SASL_PASSWORD=${AWS_SECRET:aifilm/production/kafka-password}
KAFKA_TOPIC_VIDEOS=aifilm.videos
KAFKA_TOPIC_EVENTS=aifilm.events
KAFKA_CONSUMER_GROUP=aifilm-production

# RabbitMQ (Alternative Queue)
RABBITMQ_ENABLED=false
RABBITMQ_URL=amqps://user:pass@rabbitmq.aifilm.internal:5671
RABBITMQ_VHOST=/production

# ============================================================================
# AI MODEL CONFIGURATION (GPU Cluster)
# ============================================================================
MODEL_CACHE_DIR=/mnt/efs/models/cache
MODEL_STORAGE_TYPE=efs  # efs | s3
MODEL_DOWNLOAD_TIMEOUT=3600
MODEL_AUTO_UPDATE=true
MODEL_VERSION_PINNING=true

# GPU Configuration
USE_GPU=true
GPU_DEVICE=0,1,2,3  # Multi-GPU support
GPU_MEMORY_FRACTION=0.9
CUDA_VISIBLE_DEVICES=0,1,2,3
TORCH_CUDA_ARCH_LIST=8.0;8.6;8.9

# Model Serving
MODEL_SERVING_TYPE=triton  # triton | torchserve | custom
TRITON_SERVER_URL=http://triton.aifilm.internal:8000
TRITON_GRPC_URL=grpc://triton.aifilm.internal:8001
MODEL_BATCH_SIZE=8
MODEL_MAX_QUEUE_SIZE=100

# Video Generation Limits
MAX_VIDEO_DURATION=300  # 5 minutes
MAX_RESOLUTION=3840x2160  # 4K
MAX_FPS=60
MAX_BATCH_SIZE=10
MIN_VIDEO_QUALITY=high

# ============================================================================
# AUTONOMOUS AGENT CONFIGURATION
# ============================================================================

# Agent System
AGENT_SYSTEM_ENABLED=true
AGENT_ORCHESTRATOR_TIMEOUT=7200  # 2 hours max per film
AGENT_PARALLEL_EXECUTION=true
AGENT_AUTO_APPROVE=false  # Require human approval at key stages
AGENT_MAX_ITERATIONS=5  # Max revision iterations
AGENT_MEMORY_SIZE=200  # Items per agent memory

# LLM Configuration for Agents
AGENT_LLM_PROVIDER=openai  # openai | anthropic | azure-openai | google
AGENT_LLM_MODEL=gpt-4-turbo-preview
AGENT_LLM_FALLBACK_MODEL=gpt-4
AGENT_LLM_MAX_TOKENS=4096
AGENT_LLM_TIMEOUT=60
AGENT_LLM_RETRY_ATTEMPTS=3

# Director Agent
DIRECTOR_AGENT_ENABLED=true
DIRECTOR_AGENT_MODEL=gpt-4-turbo-preview
DIRECTOR_AGENT_TEMPERATURE=0.8  # High creativity
DIRECTOR_AGENT_MAX_TOKENS=4096
DIRECTOR_AGENT_SYSTEM_PROMPT="You are an expert AI film director with decades of experience in cinematography, storytelling, and visual arts."

# Screenwriter Agent
SCREENWRITER_AGENT_ENABLED=true
SCREENWRITER_AGENT_MODEL=gpt-4-turbo-preview
SCREENWRITER_AGENT_TEMPERATURE=0.9  # Highest creativity for writing
SCREENWRITER_AGENT_MAX_TOKENS=8192  # Longer outputs for scripts
SCREENWRITER_AGENT_SYSTEM_PROMPT="You are a professional screenwriter skilled in narrative structure, dialogue, and visual storytelling."

# Editor Agent
EDITOR_AGENT_ENABLED=true
EDITOR_AGENT_MODEL=gpt-4-turbo-preview
EDITOR_AGENT_TEMPERATURE=0.6  # Balanced creativity and precision
EDITOR_AGENT_MAX_TOKENS=4096
EDITOR_AGENT_SYSTEM_PROMPT="You are a professional film editor with expertise in pacing, rhythm, and visual storytelling through editing."

# Cinematographer Agent (Coming Soon)
CINEMATOGRAPHER_AGENT_ENABLED=false
CINEMATOGRAPHER_AGENT_MODEL=gpt-4-turbo-preview
CINEMATOGRAPHER_AGENT_TEMPERATURE=0.7
CINEMATOGRAPHER_AGENT_MAX_TOKENS=4096

# Sound Designer Agent (Coming Soon)
SOUND_DESIGNER_AGENT_ENABLED=false
SOUND_DESIGNER_AGENT_MODEL=gpt-4-turbo-preview
SOUND_DESIGNER_AGENT_TEMPERATURE=0.7
SOUND_DESIGNER_AGENT_MAX_TOKENS=4096

# VFX Agent (Coming Soon)
VFX_AGENT_ENABLED=false
VFX_AGENT_MODEL=gpt-4-turbo-preview
VFX_AGENT_TEMPERATURE=0.6
VFX_AGENT_MAX_TOKENS=4096

# Agent Communication
AGENT_MESSAGE_QUEUE_ENABLED=true
AGENT_MESSAGE_TIMEOUT=30
AGENT_COLLABORATION_MODE=sequential  # sequential | parallel

# Workflow Stages
WORKFLOW_STAGE_TIMEOUT_CONCEPT=300  # 5 minutes
WORKFLOW_STAGE_TIMEOUT_SCRIPT=600  # 10 minutes
WORKFLOW_STAGE_TIMEOUT_PREPRODUCTION=600
WORKFLOW_STAGE_TIMEOUT_PRODUCTION=3600  # 1 hour for AI generation
WORKFLOW_STAGE_TIMEOUT_POSTPRODUCTION=1800  # 30 minutes
WORKFLOW_STAGE_TIMEOUT_FINALIZATION=300

# Human Oversight
HUMAN_APPROVAL_REQUIRED_STAGES=script,finalization
HUMAN_APPROVAL_TIMEOUT=86400  # 24 hours
HUMAN_INTERVENTION_ENABLED=true

# Agent Monitoring
AGENT_TELEMETRY_ENABLED=true
AGENT_METRICS_ENDPOINT=/api/v1/autonomous/metrics
AGENT_STATUS_UPDATE_INTERVAL=5  # seconds
AGENT_LOGGING_LEVEL=INFO

# ============================================================================
# RATE LIMITING & QUOTAS (Enterprise Tier)
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE=redis
RATE_LIMIT_STRATEGY=sliding-window

# Per-User Limits
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000
RATE_LIMIT_REQUESTS_PER_DAY=10000
RATE_LIMIT_CONCURRENT_REQUESTS=10

# Per-IP Limits
RATE_LIMIT_IP_REQUESTS_PER_MINUTE=100
RATE_LIMIT_IP_REQUESTS_PER_HOUR=5000

# API Quotas (Enterprise)
QUOTA_VIDEOS_PER_MONTH=1000
QUOTA_STORAGE_GB=1000
QUOTA_AI_GENERATIONS_PER_MONTH=5000
QUOTA_PROCESSING_HOURS_PER_MONTH=500

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================

# Application Performance Monitoring
APM_ENABLED=true
APM_PROVIDER=datadog  # datadog | newrelic | dynatrace | elastic
DATADOG_API_KEY=${AWS_SECRET:aifilm/production/datadog-api-key}
DATADOG_APP_KEY=${AWS_SECRET:aifilm/production/datadog-app-key}
DATADOG_SITE=datadoghq.com
DATADOG_SERVICE=ai-film-studio
DATADOG_ENV=production
DATADOG_VERSION=1.0.0
DATADOG_TRACE_ENABLED=true
DATADOG_PROFILING_ENABLED=true

# Metrics (Prometheus)
METRICS_ENABLED=true
METRICS_PORT=9090
PROMETHEUS_PUSHGATEWAY=http://prometheus-pushgateway.aifilm.internal:9091
GRAFANA_URL=https://grafana.ai-film.com

# Distributed Tracing
TRACING_ENABLED=true
TRACING_PROVIDER=jaeger  # jaeger | zipkin | aws-xray
JAEGER_AGENT_HOST=jaeger.aifilm.internal
JAEGER_AGENT_PORT=6831
JAEGER_SAMPLER_TYPE=probabilistic
JAEGER_SAMPLER_PARAM=0.1

# AWS X-Ray
XRAY_ENABLED=true
XRAY_DAEMON_ADDRESS=xray-daemon.aifilm.internal:2000

# Error Tracking
SENTRY_ENABLED=true
SENTRY_DSN=${AWS_SECRET:aifilm/production/sentry-dsn}
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ============================================================================
# LOGGING (Centralized)
# ============================================================================
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json
LOG_OUTPUT=stdout  # stdout | file | both
LOG_FILE=/var/log/aifilm/app.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=10
LOG_COMPRESSION=gzip

# Centralized Logging
LOG_AGGREGATION=true
LOG_AGGREGATION_PROVIDER=elasticsearch  # elasticsearch | splunk | datadog | cloudwatch

# Elasticsearch (ELK Stack)
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_HOSTS=https://es-1.aifilm.internal:9200,https://es-2.aifilm.internal:9200
ELASTICSEARCH_USERNAME=${AWS_SECRET:aifilm/production/es-username}
ELASTICSEARCH_PASSWORD=${AWS_SECRET:aifilm/production/es-password}
ELASTICSEARCH_INDEX=aifilm-production
ELASTICSEARCH_SSL_VERIFY=true

# AWS CloudWatch Logs
CLOUDWATCH_ENABLED=true
CLOUDWATCH_LOG_GROUP=/aws/ecs/aifilm-production
CLOUDWATCH_LOG_STREAM=app
CLOUDWATCH_REGION=us-east-1

# Audit Logging (Compliance)
AUDIT_LOG_ENABLED=true
AUDIT_LOG_DESTINATION=s3://aifilm-prod-audit-logs/
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years for compliance

# ============================================================================
# VIDEO PROCESSING (Distributed)
# ============================================================================
FFMPEG_PATH=/usr/bin/ffmpeg
FFMPEG_THREADS=4
FFMPEG_PRESET=medium  # ultrafast | fast | medium | slow
FFMPEG_CRF=23  # Quality (lower = better, 18-28 recommended)
FFMPEG_HARDWARE_ACCELERATION=cuda  # cuda | qsv | vaapi | videotoolbox

# Temp Storage
TEMP_DIR=/mnt/nvme/temp
TEMP_CLEANUP_INTERVAL=3600
TEMP_MAX_AGE=86400

# Processing Limits
MAX_UPLOAD_SIZE=5368709120  # 5GB
MAX_CONCURRENT_JOBS=50
PROCESSING_TIMEOUT=7200  # 2 hours
THUMBNAIL_GENERATION=true
VIDEO_PREVIEW_GENERATION=true

# ============================================================================
# HEALTH CHECKS & SERVICE DISCOVERY
# ============================================================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
READINESS_CHECK_PATH=/ready
LIVENESS_CHECK_PATH=/live

# Service Discovery (Consul / AWS Service Discovery)
SERVICE_DISCOVERY_ENABLED=true
SERVICE_DISCOVERY_PROVIDER=aws  # aws | consul | eureka
AWS_SERVICE_DISCOVERY_NAMESPACE=aifilm.local
AWS_SERVICE_DISCOVERY_SERVICE=api

# ============================================================================
# BACKUP & DISASTER RECOVERY
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM UTC
BACKUP_RETENTION_DAYS=90
BACKUP_ENCRYPTION=true
BACKUP_DESTINATION=s3://aifilm-prod-backups/

# Disaster Recovery
DR_ENABLED=true
DR_REGION=eu-west-1
DR_RTO=3600  # 1 hour Recovery Time Objective
DR_RPO=300   # 5 minutes Recovery Point Objective
MULTI_REGION_REPLICATION=true

# ============================================================================
# COMPLIANCE & GOVERNANCE
# ============================================================================
COMPLIANCE_MODE=strict
GDPR_ENABLED=true
HIPAA_ENABLED=false
SOC2_ENABLED=true
PCI_DSS_ENABLED=false

# Data Retention
DATA_RETENTION_DAYS=730  # 2 years
USER_DATA_DELETION_GRACE_PERIOD=30
ANONYMOUS_DATA_RETENTION=true

# Privacy
ANONYMIZE_LOGS=true
MASK_SENSITIVE_DATA=true
DATA_RESIDENCY=us  # us | eu | asia

# ============================================================================
# FEATURE FLAGS & A/B TESTING
# ============================================================================
FEATURE_FLAGS_ENABLED=true
FEATURE_FLAGS_PROVIDER=launchdarkly  # launchdarkly | optimizely | split
LAUNCHDARKLY_SDK_KEY=${AWS_SECRET:aifilm/production/launchdarkly-key}
LAUNCHDARKLY_ENVIRONMENT=production

# ============================================================================
# NOTIFICATION & ALERTS
# ============================================================================
NOTIFICATIONS_ENABLED=true
EMAIL_PROVIDER=ses  # ses | sendgrid | mailgun
AWS_SES_REGION=us-east-1
EMAIL_FROM=noreply@ai-film.com

# Slack Alerts
SLACK_WEBHOOK_URL=${AWS_SECRET:aifilm/production/slack-webhook}
SLACK_CHANNEL=#aifilm-alerts
SLACK_ALERT_LEVEL=error

# PagerDuty
PAGERDUTY_ENABLED=true
PAGERDUTY_INTEGRATION_KEY=${AWS_SECRET:aifilm/production/pagerduty-key}

# SMS Alerts (Twilio)
TWILIO_ACCOUNT_SID=${AWS_SECRET:aifilm/production/twilio-sid}
TWILIO_AUTH_TOKEN=${AWS_SECRET:aifilm/production/twilio-token}
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# KUBERNETES & CONTAINER ORCHESTRATION
# ============================================================================
KUBERNETES_ENABLED=true
K8S_NAMESPACE=production
K8S_SERVICE_ACCOUNT=aifilm-api
K8S_CLUSTER_NAME=aifilm-prod-cluster
K8S_CLUSTER_REGION=us-east-1

# Auto Scaling
AUTOSCALING_ENABLED=true
MIN_REPLICAS=3
MAX_REPLICAS=50
TARGET_CPU_UTILIZATION=70
TARGET_MEMORY_UTILIZATION=80
SCALE_UP_COOLDOWN=180
SCALE_DOWN_COOLDOWN=300

# Resource Limits
CPU_REQUEST=1000m
CPU_LIMIT=2000m
MEMORY_REQUEST=2Gi
MEMORY_LIMIT=4Gi

# ============================================================================
# API GATEWAY & LOAD BALANCING
# ============================================================================
API_GATEWAY_ENABLED=true
API_GATEWAY_TYPE=aws  # aws | kong | nginx | traefik
LOAD_BALANCER_TYPE=application  # application | network
LOAD_BALANCER_DNS=api.ai-film.com
LOAD_BALANCER_SCHEME=internet-facing
STICKY_SESSIONS=true
CONNECTION_DRAINING=true
IDLE_TIMEOUT=60

# Circuit Breaker
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_THRESHOLD=50
CIRCUIT_BREAKER_TIMEOUT=30
CIRCUIT_BREAKER_RETRY_AFTER=60

# ============================================================================
# END OF CONFIGURATION
# ============================================================================
