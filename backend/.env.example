# Application Settings
APP_NAME=AI-Film-Studio
APP_ENV=development
DEBUG=True
API_VERSION=v1
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_film_studio
POSTGRES_USER=filmstudio
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ai_film_studio

# Redis
REDIS_URL=redis://localhost:6379/0

# AI Service API Keys
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
STABILITY_API_KEY=sk-your-stability-key
ELEVENLABS_API_KEY=your-elevenlabs-key
REPLICATE_API_TOKEN=your-replicate-token

# Cloud Storage (choose one)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
S3_BUCKET_NAME=ai-film-studio

# Azure Alternative
AZURE_STORAGE_CONNECTION_STRING=your-azure-connection
AZURE_CONTAINER_NAME=videos

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# File Upload Settings
MAX_UPLOAD_SIZE=104857600  # 100MB
ALLOWED_EXTENSIONS=.mp4,.mov,.avi,.png,.jpg,.jpeg

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
